# Load Nix flake environment if available; otherwise check for dependencies
if has nix; then
    use flake
else
    _missing=()
    for cmd in yt-dlp ffmpeg magick mkvmerge; do
        has "$cmd" || _missing+=("$cmd")
    done
    if [[ ${#_missing[@]} -gt 0 ]]; then
        log_error "Missing dependencies: ${_missing[*]}"
        log_error "Install with: brew install yt-dlp ffmpeg imagemagick mkvtoolnix"
        return 1
    fi
    unset _missing
fi

for init_dir in .envrc.d .envrc.local.d
do
    if [[ -d "$init_dir" ]]
    then
        for f in "$init_dir"/*
        do
            source "$f"
        done
    fi
done
